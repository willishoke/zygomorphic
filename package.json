{
  "name": "zygomorphic",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/electron/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.electron.json",
    "start": "npm run build && electron .",
    "make-icon": "node scripts/make-icon.mjs",
    "package": "npm run build && electron-builder",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "build": {
    "appId": "com.zygomorphic.app",
    "productName": "Zygomorphic",
    "icon": "assets/icon.png",
    "directories": {
      "output": "dist/packages"
    },
    "files": [
      "dist/electron/**",
      "src/web/**",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "category": "Development",
      "target": "AppImage"
    },
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "electron": "^34.0.0"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^25.5.0",
    "electron-builder": "^26.8.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.2"
  }
}
